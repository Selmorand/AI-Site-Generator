<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS Reverse Proxy to Node.js Express server.

  WHY: The dashboard is a live Node.js process (Express server) that handles
  API requests, runs OpenAI calls, streams SSE progress events, and serves
  generated site previews. IIS cannot execute this from static files — it
  needs to forward requests to the running Node process.

  REQUIRES:
    1. URL Rewrite module (https://www.iis.net/downloads/microsoft/url-rewrite)
    2. Application Request Routing (https://www.iis.net/downloads/microsoft/application-request-routing)
    3. Enable ARR proxy: IIS Manager > Server > Application Request Routing > Server Proxy Settings > Enable proxy
    4. Node app running via: npx tsx src/server.ts (default port 3500, set PORT env var to change)
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="ReverseProxy" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:3500/{R:1}" />
        </rule>
      </rules>
    </rewrite>
    <!-- Increase timeout for long-running generation requests (SSE streams) -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
